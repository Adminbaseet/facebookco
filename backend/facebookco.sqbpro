-- rate the person that post most</sql><sql name="&amp;Foreign-Key Check">PRAGMA foreign_key_check;</sql><sql name="&amp;Optimize*">PRAGMA optimize;</sql><sql name="Show &amp;Row Counts*">SELECT 'coins' AS &quot;name&quot;, 'table' AS &quot;type&quot;, COUNT(*) AS &quot;rows&quot; FROM &quot;coins&quot;
