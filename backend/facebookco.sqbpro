UNION SELECT 'users' AS &quot;name&quot;, 'table' AS &quot;type&quot;, COUNT(*) AS &quot;rows&quot; FROM &quot;users&quot;</sql><sql name="&amp;Quick Integrity Check*">PRAGMA quick_check;</sql><sql name="&amp;Integrity Check*">PRAGMA integrity_check;</sql><current_tab id="5"/></tab_sql></sqlb_project>
